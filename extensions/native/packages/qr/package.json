{
  "name": "@simplix-react-native-ext/qr",
  "version": "0.3.0",
  "description": "QR display for simplix-react-native: static QR rendering and rotating presence-token QR with remaining-validity display",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "sideEffects": [
    "./src/index.ts",
    "./src/locales/*"
  ],
  "files": [
    "src"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "qrcode": "catalog:"
  },
  "peerDependencies": {
    "@simplix-react-native/ui": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-svg": ">=15.0.0"
  },
  "devDependencies": {
    "@simplix-react-native/ui": "workspace:*",
    "@simplix-react/config-typescript": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "@types/qrcode": "catalog:",
    "@types/react": "catalog:",
    "nativewind": "catalog:",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-svg": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "simplix-react",
    "react-native",
    "qr"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simplix-react/simplix-react.git"
  }
}
