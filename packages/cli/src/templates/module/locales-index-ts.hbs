import { buildModuleTranslations, registerModuleTranslations } from "@simplix-react/i18n";

/**
 * The i18n namespace under which this module's translations are registered.
 */
export const PACKAGE_NAMESPACE = "{{namespace}}";

const translations = buildModuleTranslations({
  namespace: PACKAGE_NAMESPACE,
  locales: {{{json locales}}},
  components: {
    // CLI will auto-populate as features/widgets are added
    // Example:
    // "widgets/editor": {
    //   ko: () => import("./widgets/editor/ko.json"),
    //   en: () => import("./widgets/editor/en.json"),
    //   ja: () => import("./widgets/editor/ja.json"),
    // },
  },
});

registerModuleTranslations(translations);
