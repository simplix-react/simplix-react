import { useCallback, useState } from "react";
import type { CrudSearch } from "@simplix-react/ui";
import { {{#if hasCreate}}Button, {{/if}}Container, ListDetail, Stack{{#if hasTreeMove}}, TreeMoveDialog{{/if}}{{#if hasTreeReorder}}, TreeReorderDialog{{/if}}{{#if hasDelete}}, adaptOrvalDelete{{/if}}{{#if hasTreeReorder}}, getSiblings{{/if}}{{#if hasDelete}}, useCrudDeleteWired{{/if}}, useCrudNavigation, useCrudPageState{{#if hasDelete}}, useInvalidateEntity{{/if}}, usePageHeader } from "@simplix-react/ui";
import { useTranslation } from "@simplix-react/i18n/react";
{{#if hasCreate}}
import { PlusIcon } from "lucide-react";
{{/if}}
{{#if packageName}}
import { {{#if hookDelete}}{{hookDelete}}, {{/if}}{{#if hookUpdate}}{{hookUpdate}}{{/if}} } from "{{packageName}}";
{{/if}}

import { {{#if hasDetail}}{{EntityPascal}}Detail, {{/if}}{{#if hasForm}}{{EntityPascal}}Form, {{/if}}{{EntityPascal}}Tree, use{{EntityPascal}}Tree } from "../../widgets";

interface {{EntityPascal}} {
{{#each fields}}
{{#if (eq this.name ../treeParentIdField)}}
  {{this.name}}: string | null;
{{else}}
  {{this.name}}: {{this.tsType}};
{{/if}}
{{/each}}
  children: {{EntityPascal}}[];
}

interface {{EntityPascal}}CrudPageProps {
  variant?: "panel" | "dialog" | "page";
  search: CrudSearch;
  onNavigate: (search: CrudSearch) => void;
}

export function {{EntityPascal}}CrudPage({ variant = "panel", search, onNavigate }: {{EntityPascal}}CrudPageProps) {
  const tree = use{{EntityPascal}}Tree();
  const { t } = useTranslation("{{moduleNamespace}}/widgets");

  const nav = useCrudNavigation(search, onNavigate);
  const { view, selectedId, showList, showDetail{{#if hasCreate}}, showNew{{/if}}{{#if hasUpdate}}, showEdit{{/if}} } = nav;

{{#if hasDelete}}
{{#if hookDelete}}
  const invalidate = useInvalidateEntity("{{entityPath}}");
  const { requestDelete, deleteDialog } = useCrudDeleteWired({
    deleteMutation: adaptOrvalDelete({{hookDelete}}(), "{{deletePathParam}}", { onSettled: invalidate }),
    labels: {
      title: () => t("{{entity}}.delete{{EntityPascal}}Title"),
      description: (target) => t("{{entity}}.delete{{EntityPascal}}Desc", { name: target.name }),
      cancel: t("common.cancel"),
      delete: t("common.delete"),
      deleting: t("common.deleting"),
    },
    onDeleted: showList,
  });
{{else}}
  // TODO: Wire up delete mutation from your domain package
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const { requestDelete, deleteDialog } = useCrudDeleteWired({
    deleteMutation: { mutate: (() => {}) as (...args: unknown[]) => void, isPending: false } as any,
    labels: {
      title: () => t("{{entity}}.delete{{EntityPascal}}Title"),
      description: (target) => t("{{entity}}.delete{{EntityPascal}}Desc", { name: target.name }),
      cancel: t("common.cancel"),
      delete: t("common.delete"),
      deleting: t("common.deleting"),
    },
    onDeleted: showList,
  });
{{/if}}
{{/if}}

{{#if hasCreate}}
  // ── Add-child state ──
  const [newParentId, setNewParentId] = useState<string | null>(null);
{{/if}}

{{#if hasTreeReorder}}
  // ── Reorder dialog state ──
  const [reorderTarget, setReorderTarget] = useState<{ parentId: string | null } | null>(null);
{{/if}}

{{#if hasTreeMove}}
  // ── Move dialog state ──
  const [moveTarget, setMoveTarget] = useState<{ id: string; parentId: string | null } | null>(null);
{{/if}}
{{#if hookUpdate}}
  const _update = {{hookUpdate}}();
{{/if}}

{{#if hasTreeMove}}
  const handleMove = useCallback(
    (itemId: string, newParentId: string | null) => {
      // eslint-disable-next-line @typescript-eslint/no-explicit-any
      (_update as any).mutate({ {{updateMutationKey}}: itemId, data: { {{treeParentIdField}}: newParentId } }, {
        onSuccess: () => setMoveTarget(null),
      });
    },
    [_update],
  );
{{/if}}

  // ── Row actions ──

  const pageActions = [
{{#if hasDetail}}
    { type: "view" as const, onClick: (row: {{EntityPascal}}) => showDetail(String(row.{{rowIdField}})) },
{{/if}}
{{#if hasUpdate}}
    { type: "edit" as const, onClick: (row: {{EntityPascal}}) => showEdit(String(row.{{rowIdField}})) },
{{/if}}
{{#if hasCreate}}
    { type: "add-child" as const, onClick: (row: {{EntityPascal}}) => {
      setNewParentId(String(row.{{rowIdField}}));
      showNew();
    }},
{{/if}}
{{#if hasTreeReorder}}
    { type: "reorder" as const, onClick: (row: {{EntityPascal}}) => {
      setReorderTarget({ parentId: row.{{treeParentIdField}} });
    }},
{{/if}}
{{#if hasTreeMove}}
    { type: "move" as const, onClick: (row: {{EntityPascal}}) => {
      setMoveTarget({ id: String(row.{{rowIdField}}), parentId: row.{{treeParentIdField}} });
    }},
{{/if}}
{{#if hasDelete}}
    { type: "delete" as const, onClick: (row: {{EntityPascal}}) => requestDelete({ id: row.{{rowIdField}}!, name: String(row.{{treeDisplayNameField}}) }) },
{{/if}}
  ];

  const { state, fade, closePanel } = useCrudPageState(variant, nav);

  usePageHeader((() => {
    if (variant === "page") {
{{#if hasCreate}}
      if (view === "new") return { title: t("{{entity}}.new{{EntityPascal}}") };
{{/if}}
{{#if hasUpdate}}
      if (view === "edit") return { title: t("{{entity}}.edit{{EntityPascal}}") };
{{/if}}
{{#if hasDetail}}
      if (view === "detail") return { title: t("{{entity}}.{{entity}}Detail") };
{{/if}}
      return {
        title: t("{{entity}}.{{entityPlural}}"),
{{#if hasCreate}}
        actions: <Button onClick={showNew}><PlusIcon className="size-4" />{t("{{entity}}.addNew{{EntityPascal}}")}</Button>,
{{/if}}
      };
    }
    return {
      title: t("{{entity}}.{{entityPlural}}"),
      description: t("{{entity}}.{{entityPlural}}Description"),
{{#if hasCreate}}
      actions: <Button onClick={showNew}><PlusIcon className="size-4" />{t("{{entity}}.addNew{{EntityPascal}}")}</Button>,
{{/if}}
    };
  })());

  // ── Page variant: full-page view switching ──

  if (variant === "page") {
{{#if hasCreate}}
    if (view === "new") {
      return (
        <Container size="full">
          <{{EntityPascal}}Form
            key={newParentId ?? "new"}
            defaultParentId={newParentId}
            onSuccess={() => { setNewParentId(null); showList(); }}
            onBack={() => { setNewParentId(null); showList(); }}
          />
        </Container>
      );
    }
{{/if}}

{{#if hasUpdate}}
    if (view === "edit" && selectedId) {
      return (
        <Container size="full">
          <{{EntityPascal}}Form
            {{entity}}Id={selectedId}
            onSuccess={() => showDetail(selectedId)}
            onBack={() => showDetail(selectedId)}
          />
        </Container>
      );
    }
{{/if}}

{{#if hasDetail}}
    if (view === "detail" && selectedId) {
      return (
        <Container size="full">
          <{{EntityPascal}}Detail
            {{entity}}Id={selectedId}
            onBack={showList}
{{#if hasUpdate}}
            onEdit={() => showEdit(selectedId)}
{{/if}}
{{#if hasDelete}}
            onDeleted={showList}
{{/if}}
          />
        </Container>
      );
    }
{{/if}}

    return (
      <Container size="full">
        <Stack gap="md">
          <{{EntityPascal}}Tree
            tree={tree}
{{#if hasDetail}}
            onRowClick={(row) => showDetail(String(row.{{rowIdField}}))}
{{/if}}
            actions={pageActions}
          />
        </Stack>
{{#if hasDelete}}
        {deleteDialog}
{{/if}}
{{#if hasTreeReorder}}
        {reorderTarget && (
          <TreeReorderDialog<{{EntityPascal}}>
            open
            onOpenChange={(open) => { if (!open) setReorderTarget(null); }}
            parentId={reorderTarget.parentId}
            siblings={getSiblings(tree.data, reorderTarget.parentId, { idField: "{{rowIdField}}", childrenField: "children" })}
            config={{ldb}}
              orderField: "{{treeSortOrderField}}",
              idField: "{{rowIdField}}",
              onReorder: (_parentId, items) => {
                items.forEach((item, i) => {
                  // eslint-disable-next-line @typescript-eslint/no-explicit-any
                  (_update as any).mutate({ {{updateMutationKey}}: (item as {{EntityPascal}}).{{rowIdField}}, data: { {{treeSortOrderField}}: (i + 1) * 10 } });
                });
                setReorderTarget(null);
              },
            {{rdb}}
            getDisplayName={(d) => d.{{treeDisplayNameField}} ?? ""}
          />
        )}
{{/if}}
{{#if hasTreeMove}}
        {moveTarget && (
          <TreeMoveDialog<{{EntityPascal}}>
            open
            onOpenChange={(open) => { if (!open) setMoveTarget(null); }}
            treeData={tree.data}
            currentItemId={moveTarget.id}
            currentParentId={moveTarget.parentId}
            config={{ldb}}
              idField: "{{rowIdField}}",
              parentIdField: "{{treeParentIdField}}",
              getDisplayName: (d) => d.{{treeDisplayNameField}} ?? "",
              onMove: handleMove,
            {{rdb}}
          />
        )}
{{/if}}
      </Container>
    );
  }

  // ── Panel / Dialog variant: ListDetail layout ──

  return (
    <>
    <Stack flex gap="md">
      <ListDetail variant={variant} activePanel={view === "list" ? "list" : "detail"} detailWidth={480}
                  onClose={showList}>
        <ListDetail.List>
          <{{EntityPascal}}Tree
            tree={tree}
            activeRowId={selectedId}
            onRowClick={(row) => showDetail(String(row.{{rowIdField}}))}
            actions={[
              { type: "view", onClick: (row: {{EntityPascal}}) => showDetail(String(row.{{rowIdField}})) },
{{#if hasCreate}}
              { type: "add-child", onClick: (row: {{EntityPascal}}) => { setNewParentId(String(row.{{rowIdField}})); showNew(); } },
{{/if}}
{{#if hasTreeReorder}}
              { type: "reorder", onClick: (row: {{EntityPascal}}) => { setReorderTarget({ parentId: row.{{treeParentIdField}} }); } },
{{/if}}
{{#if hasTreeMove}}
              { type: "move", onClick: (row: {{EntityPascal}}) => { setMoveTarget({ id: String(row.{{rowIdField}}), parentId: row.{{treeParentIdField}} }); } },
{{/if}}
            ]}
          />
        </ListDetail.List>

        <ListDetail.Detail>
          <ListDetail.ViewSwitch
            state={state}
            fade={fade}
            renderDetail={(id) => (
              <{{EntityPascal}}Detail
                {{entity}}Id={id}
                onClose={closePanel}
{{#if hasUpdate}}
                onEdit={() => showEdit(id)}
{{/if}}
{{#if hasDelete}}
                onDeleted={showList}
{{/if}}
              />
            )}
{{#if hasCreate}}
            renderNew={() => (
              <{{EntityPascal}}Form
                key={newParentId ?? "new"}
                defaultParentId={newParentId}
                onClose={() => { setNewParentId(null); closePanel?.(); }}
                onSuccess={() => { setNewParentId(null); showList(); }}
                onCancel={() => { setNewParentId(null); showList(); }}
              />
            )}
{{/if}}
{{#if hasUpdate}}
            renderEdit={(id) => (
              <{{EntityPascal}}Form
                {{entity}}Id={id}
                onClose={closePanel}
                onSuccess={() => showDetail(id)}
                onCancel={() => showDetail(id)}
              />
            )}
{{/if}}
          />
        </ListDetail.Detail>
      </ListDetail>
    </Stack>
{{#if hasDelete}}
    {deleteDialog}
{{/if}}
{{#if hasTreeReorder}}
    {reorderTarget && (
      <TreeReorderDialog<{{EntityPascal}}>
        open
        onOpenChange={(open) => { if (!open) setReorderTarget(null); }}
        parentId={reorderTarget.parentId}
        siblings={getSiblings(tree.data, reorderTarget.parentId, { idField: "{{rowIdField}}", childrenField: "children" })}
        config={{ldb}}
          orderField: "{{treeSortOrderField}}",
          idField: "{{rowIdField}}",
          onReorder: (_parentId, items) => {
            items.forEach((item, i) => {
              // eslint-disable-next-line @typescript-eslint/no-explicit-any
              (_update as any).mutate({ {{updateMutationKey}}: (item as {{EntityPascal}}).{{rowIdField}}, data: { {{treeSortOrderField}}: (i + 1) * 10 } });
            });
            setReorderTarget(null);
          },
        {{rdb}}
        getDisplayName={(d) => d.{{treeDisplayNameField}} ?? ""}
      />
    )}
{{/if}}
{{#if hasTreeMove}}
    {moveTarget && (
      <TreeMoveDialog<{{EntityPascal}}>
        open
        onOpenChange={(open) => { if (!open) setMoveTarget(null); }}
        treeData={tree.data}
        currentItemId={moveTarget.id}
        currentParentId={moveTarget.parentId}
        config={{ldb}}
          idField: "{{rowIdField}}",
          parentIdField: "{{treeParentIdField}}",
          getDisplayName: (d) => d.{{treeDisplayNameField}} ?? "",
          onMove: handleMove,
        {{rdb}}
      />
    )}
{{/if}}
    </>
  );
}
