{
  "name": "@simplix-react-ext/simplix-boot-cli-plugin",
  "version": "0.2.1",
  "description": "CLI plugin for simplix-boot OpenAPI spec profile",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@simplix-react/cli": "workspace:*"
  },
  "devDependencies": {
    "@simplix-react/cli": "workspace:*",
    "@simplix-react/contract": "workspace:*",
    "@simplix-react/config-typescript": "workspace:*",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
