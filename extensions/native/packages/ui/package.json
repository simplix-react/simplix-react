{
  "name": "@simplix-react-native/ui",
  "version": "0.3.0",
  "description": "Standard mobile UI kit for simplix-react on React Native: layout primitives, page skeletons, controls, sheet-first overlays, FormFields / DetailFields, EntityList + useEntityFeed, theme token sheet",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./tailwind-preset": "./tailwind-preset.cjs"
  },
  "sideEffects": [
    "./src/index.ts",
    "**/index.ts",
    "**/locales/**"
  ],
  "files": [
    "src",
    "tailwind-preset.cjs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf .turbo"
  },
  "dependencies": {
    "@rn-primitives/alert-dialog": "catalog:",
    "@rn-primitives/checkbox": "catalog:",
    "@rn-primitives/dialog": "catalog:",
    "@rn-primitives/label": "catalog:",
    "@rn-primitives/popover": "catalog:",
    "@rn-primitives/portal": "catalog:",
    "@rn-primitives/radio-group": "catalog:",
    "@rn-primitives/separator": "catalog:",
    "@rn-primitives/slot": "catalog:",
    "@rn-primitives/switch": "catalog:",
    "@rn-primitives/tabs": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "libphonenumber-js": "catalog:",
    "tailwind-merge": "catalog:"
  },
  "peerDependencies": {
    "@react-native-community/datetimepicker": ">=8.0.0",
    "@simplix-react/headless": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "expo-document-picker": ">=13.0.0",
    "expo-image-picker": ">=16.0.0",
    "nativewind": ">=4.0.0",
    "react": ">=18.0.0",
    "react-native": ">=0.76.0",
    "react-native-safe-area-context": ">=5.0.0"
  },
  "devDependencies": {
    "@react-native-community/datetimepicker": "catalog:",
    "@simplix-react/config-typescript": "workspace:*",
    "@simplix-react/headless": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "expo-document-picker": "catalog:",
    "expo-image-picker": "catalog:",
    "jsdom": "catalog:",
    "nativewind": "catalog:",
    "react": "catalog:",
    "react-native": "catalog:",
    "react-native-safe-area-context": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "simplix-react",
    "react-native",
    "expo",
    "nativewind",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simplix-react/simplix-react.git"
  }
}
