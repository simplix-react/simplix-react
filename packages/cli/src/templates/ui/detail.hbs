import { QueryFallback, {{#if hasDelete}}CrudDelete, useCrudDeleteDetail, adaptOrvalDelete, {{/if}}CrudDetail, DetailFields, {{#if hasBooleanFields}}DetailFieldWrapper, BooleanBadge, {{/if}}Heading, usePreviousData{{#if hookDelete}}, useInvalidateEntity{{/if}} } from "@simplix-react/ui";
import type { EntityId } from "@simplix-react/contract";
import { useEntityTranslation, useTranslation } from "@simplix-react/i18n/react";
{{#if packageName}}
import { {{#if hookGet}}{{hookGet}}{{/if}}{{#if hookDelete}}{{#if hookGet}}, {{/if}}{{hookDelete}}{{/if}} } from "{{packageName}}";
{{/if}}

interface {{EntityPascal}}DetailProps {
  {{entity}}Id: EntityId;
  onClose?: () => void;
  onBack?: () => void;
{{#if hasUpdate}}
  onEdit?: () => void;
{{/if}}
{{#if hasDelete}}
  onDeleted?: () => void;
{{/if}}
}

/**
 * Renders the read-only detail view of a single {{entity}}, with edit and delete affordances.
 */
export function {{EntityPascal}}Detail({ {{entity}}Id, onClose, onBack{{#if hasUpdate}}, onEdit{{/if}}{{#if hasDelete}}, onDeleted{{/if}} }: {{EntityPascal}}DetailProps) {
{{#if hasI18nFields}}
  const { t } = useTranslation("{{moduleNamespace}}/widgets");
{{else}}
  const { t } = useTranslation("{{moduleNamespace}}/widgets");
{{/if}}
{{#if hookGet}}
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const { data, isLoading } = {{hookGet}}({{entity}}Id as any) as any;
{{else}}
  // TODO: Wire up useGet hook from your domain package
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const data = null as any;
  const isLoading = false;
{{/if}}
{{#if hasDelete}}
{{#if hookDelete}}
  const _delete = {{hookDelete}}();
  const invalidate = useInvalidateEntity("{{entityPath}}");
  const deleteMutation = adaptOrvalDelete<EntityId>(_delete, "{{deletePathParam}}", { onSettled: invalidate });
{{else}}
  // TODO: Wire up delete mutation from your domain package
  // eslint-disable-next-line @typescript-eslint/no-explicit-any
  const deleteMutation = { mutate: (() => {}) as (...args: unknown[]) => void, isPending: false } as any;
{{/if}}
  const del = useCrudDeleteDetail();
{{/if}}

{{#unless hasEnumFields}}
  // eslint-disable-next-line @typescript-eslint/no-unused-vars
{{/unless}}
  const { fieldLabel, enumLabel } = useEntityTranslation("{{entity}}");
  const displayData = usePreviousData(data);

  if (!displayData) return <QueryFallback isLoading={isLoading} notFoundMessage="{{EntityPascal}} not found." />;

{{#if displayNameField}}
  const header = onClose ? <Heading level={4} tone="muted">{String(displayData.{{displayNameField}} ?? "")}</Heading> : undefined;
{{else}}
  const header = onClose ? <Heading level={4} tone="muted">{t("{{entity}}.detailHeader")}</Heading> : undefined;
{{/if}}

  return (
    <>
      <CrudDetail isLoading={isLoading} header={header} onClose={onClose} auditData={{ldb}} id: displayData.{{rowIdField}}, createdAt: displayData.createdAt, updatedAt: displayData.updatedAt {{rdb}} footer={
        <CrudDetail.DefaultActions
          onClose={onClose}
          onBack={onBack}
{{#if hasDelete}}
          onDelete={del.requestDelete}
          isPending={deleteMutation.isPending}
{{/if}}
{{#if hasUpdate}}
          onEdit={onEdit}
{{/if}}
        />
      }>
        <CrudDetail.Section title={t("{{entity}}.sectionTitle")} variant="flat">
{{#each fields}}
{{#unless this.isSystemField}}
{{#unless this.isI18nPair}}
{{#if (eq this.component "I18nText")}}
          <DetailFields.DetailI18nTextField
            label={fieldLabel("{{#if this.baseFieldName}}{{this.baseFieldName}}{{else}}{{this.name}}{{/if}}")}
            value={displayData.{{this.name}} as unknown as Record<string, string> | undefined}
            layout="inline"
          />
{{else if (eq this.component "I18nTextarea")}}
          <DetailFields.DetailI18nTextareaField
            label={fieldLabel("{{#if this.baseFieldName}}{{this.baseFieldName}}{{else}}{{this.name}}{{/if}}")}
            value={displayData.{{this.name}} as unknown as Record<string, string> | undefined}
            layout="top"
          />
{{else if (eq this.component "Textarea")}}
          <DetailFields.DetailTextareaField
            label={fieldLabel("{{this.name}}")}
            value={displayData.{{this.name}} as string | null | undefined}
            layout="top"
          />
{{else if (eq this.component "Date")}}
          <DetailFields.DetailDateField
            label={fieldLabel("{{this.name}}")}
            value={displayData.{{this.name~}} }
            layout="inline"
          />
{{else if (eq this.component "Number")}}
          <DetailFields.DetailNumberField
            label={fieldLabel("{{this.name}}")}
            value={displayData.{{this.name~}} }
            layout="inline"
          />
{{else if (eq this.component "Boolean")}}
          <DetailFieldWrapper label={fieldLabel("{{this.name}}")} layout="inline">
            <BooleanBadge value={!!displayData.{{this.name~}} } />
          </DetailFieldWrapper>
{{else if (eq this.component "Select")}}
          <DetailFields.DetailBadgeField
            label={fieldLabel("{{this.name}}")}
            value={displayData.{{this.name~}} }
            displayValue={enumLabel("{{../entity}}{{this.capitalizedName}}", displayData.{{this.name}})}
            variants={{ldb}} {{#each this.options}}"{{this}}": "default"{{#unless @last}}, {{/unless}}{{/each}} {{rdb}}
            layout="inline"
          />
{{else if this.isForeignKey}}
          <DetailFields.DetailTextField
            label={fieldLabel("{{this.name}}")}
            value={displayData.{{this.fkEntityField}}?.name ?? String(displayData.{{this.name}} ?? "")}
            layout="inline"
          />
{{else}}
          <DetailFields.DetailTextField
            label={fieldLabel("{{this.name}}")}
            value={String(displayData.{{this.name}} ?? "")}
            layout="inline"
          />
{{/if}}
{{/unless}}  {{!-- isI18nPair --}}
{{/unless}}  {{!-- isSystemField --}}
{{/each}}
        </CrudDetail.Section>
      </CrudDetail>
{{#if hasDelete}}
      <CrudDelete
        open={del.open}
        onOpenChange={del.onOpenChange}
        onConfirm={() => deleteMutation.mutate({{entity}}Id, { onSuccess: onDeleted })}
        title={t("{{entity}}.delete{{EntityPascal}}Title")}
{{#if displayNameField}}
        description={t("{{entity}}.delete{{EntityPascal}}Desc", { name: String(displayData.{{displayNameField}} ?? "") })}
{{else}}
        description={t("{{entity}}.delete{{EntityPascal}}DescSimple")}
{{/if}}
        loading={deleteMutation.isPending}
      />
{{/if}}
    </>
  );
}
