{
  "name": "simplix-react-ext",
  "version": "0.3.0",
  "description": "Meta package that installs all @simplix-react-ext/* extension packages (simplix-boot) in one dependency",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@simplix-react-ext/simplix-boot-access": "workspace:*",
    "@simplix-react-ext/simplix-boot-auth": "workspace:*",
    "@simplix-react-ext/simplix-boot-cli-plugin": "workspace:*",
    "@simplix-react-ext/simplix-boot-stream": "workspace:*",
    "@simplix-react-ext/simplix-boot-utils": "workspace:*"
  },
  "keywords": [
    "simplix-react",
    "simplix-boot",
    "extensions",
    "react",
    "openapi"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simplix-react/simplix-react.git"
  }
}
