{
  "name": "@simplix-react/mock",
  "version": "0.2.1",
  "description": "Auto-generated MSW handlers and in-memory stores from @simplix-react/contract",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@simplix-react/contract": "workspace:*",
    "msw": ">=2.0.0",
    "vite": ">=5.0.0",
    "zod": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "msw": {
      "optional": true
    },
    "vite": {
      "optional": true
    }
  },
  "devDependencies": {
    "@simplix-react/config-typescript": "workspace:*",
    "@simplix-react/contract": "workspace:*",
    "@types/node": "catalog:",
    "msw": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js"
}
