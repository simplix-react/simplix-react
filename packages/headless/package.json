{
  "name": "@simplix-react/headless",
  "version": "0.3.0",
  "description": "Platform-neutral headless logic shared by the web and native UI kits: Orval adapters, searchable filter serialization, toast store, formatting and date utilities, theme registry",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@simplix-react/config-typescript": "workspace:*",
    "@testing-library/react": "catalog:",
    "@types/react": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "simplix-react",
    "headless",
    "orval",
    "searchable"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/simplix-react/simplix-react.git"
  }
}
