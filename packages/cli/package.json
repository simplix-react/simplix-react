{
  "name": "@simplix-react/cli",
  "version": "0.2.2",
  "description": "CLI for scaffolding and validating simplix-react projects",
  "type": "module",
  "sideEffects": [
    "dist/bin.js"
  ],
  "bin": {
    "simplix": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@simplix-react/contract": "workspace:*",
    "commander": "catalog:",
    "handlebars": "catalog:",
    "jiti": "catalog:",
    "ora": "catalog:",
    "picocolors": "catalog:",
    "prompts": "catalog:",
    "yaml": "catalog:"
  },
  "devDependencies": {
    "@simplix-react/config-typescript": "workspace:*",
    "@types/prompts": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js"
}
