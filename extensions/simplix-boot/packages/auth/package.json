{
  "name": "@simplix-react-ext/simplix-boot-auth",
  "version": "0.2.1",
  "description": "Spring Security authentication for simplix-boot",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mock": {
      "types": "./dist/mock.d.ts",
      "import": "./dist/mock.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp -r src/locales dist/",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@simplix-react/api": "workspace:*",
    "@simplix-react/auth": "workspace:*",
    "@simplix-react/contract": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@simplix-react/api": "workspace:*",
    "@simplix-react/auth": "workspace:*",
    "@simplix-react/contract": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "@simplix-react/mock": "workspace:*",
    "@simplix-react/config-typescript": "workspace:*",
    "msw": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "zod": "catalog:"
  }
}
