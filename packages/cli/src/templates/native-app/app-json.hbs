{
  "expo": {
    "name": "{{appName}}",
    "slug": "{{appName}}",
    "version": "1.0.0",
    "scheme": "{{camelCase appName}}",
    "orientation": "default",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
