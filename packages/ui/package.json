{
  "name": "@simplix-react/ui",
  "version": "0.2.2",
  "description": "CRUD scaffolding UI components with explicit field components and compound patterns",
  "type": "module",
  "sideEffects": [
    "./dist/styles.css",
    "./dist/index.js",
    "./dist/plate-editor.js",
    "./src/locales/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./plate-editor": {
      "types": "./dist/plate-editor.d.ts",
      "import": "./dist/plate-editor.js"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "find src -name '*.d.ts' -o -name '*.d.ts.map' -o -name '*.js.map' | xargs rm -f",
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "peerDependencies": {
    "@simplix-react/api": "workspace:*",
    "@simplix-react/form": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "@simplix-react/react": "workspace:*",
    "@tanstack/react-query": ">=5.0.0",
    "react": ">=18.0.0",
    "react-router-dom": ">=6.0.0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "dependencies": {
    "@dnd-kit/core": "catalog:",
    "@dnd-kit/sortable": "catalog:",
    "@dnd-kit/utilities": "catalog:",
    "@radix-ui/react-alert-dialog": "catalog:",
    "@radix-ui/react-checkbox": "catalog:",
    "@radix-ui/react-collapsible": "catalog:",
    "@radix-ui/react-dialog": "catalog:",
    "@radix-ui/react-dropdown-menu": "catalog:",
    "@radix-ui/react-label": "catalog:",
    "@radix-ui/react-navigation-menu": "catalog:",
    "@radix-ui/react-popover": "catalog:",
    "@radix-ui/react-radio-group": "catalog:",
    "@radix-ui/react-select": "catalog:",
    "@radix-ui/react-separator": "catalog:",
    "@radix-ui/react-switch": "catalog:",
    "@radix-ui/react-tabs": "catalog:",
    "@radix-ui/react-tooltip": "catalog:",
    "@tanstack/react-table": "catalog:",
    "@tanstack/react-virtual": "catalog:",
    "apexcharts": "catalog:",
    "class-variance-authority": "catalog:",
    "clsx": "catalog:",
    "cmdk": "catalog:",
    "country-flag-icons": "catalog:",
    "dompurify": "catalog:",
    "maplibre-gl": "catalog:",
    "pmtiles": "catalog:",
    "protomaps-themes-base": "catalog:",
    "react-apexcharts": "catalog:",
    "tailwind-merge": "catalog:",
    "platejs": "catalog:",
    "@platejs/basic-nodes": "catalog:",
    "@platejs/basic-styles": "catalog:",
    "@platejs/caption": "catalog:",
    "@platejs/code-block": "catalog:",
    "@platejs/floating": "catalog:",
    "@platejs/indent": "catalog:",
    "@platejs/link": "catalog:",
    "@platejs/list-classic": "catalog:",
    "@platejs/media": "catalog:",
    "@platejs/mention": "catalog:",
    "@platejs/table": "catalog:",
    "lowlight": "catalog:",
    "lucide-react": "catalog:"
  },
  "devDependencies": {
    "@simplix-react/api": "workspace:*",
    "@simplix-react/config-typescript": "workspace:*",
    "@simplix-react/form": "workspace:*",
    "@simplix-react/i18n": "workspace:*",
    "@simplix-react/react": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@testing-library/jest-dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/dompurify": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "jsdom": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js"
}
