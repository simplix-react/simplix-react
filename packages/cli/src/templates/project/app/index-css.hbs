@import "tailwindcss";
@import "@simplix-react/ui/styles.css";
@import "@simplix-react/ui/theme.css";

/* Scan module widgets and @simplix-react/ui for Tailwind classes */
@source "../../../modules/*/src/**/*.tsx";
@source "../../../node_modules/@simplix-react/ui/dist/**/*.js";

@layer base {
  body {
    @apply m-0 font-sans antialiased text-foreground bg-background;
  }
}
